# ============================================================
# .env — Environment Variables & Secrets
# PHASE 4 — Topic 20: Environment variables and secrets management
# ============================================================
# IMPORTANT: Add .env to .gitignore — NEVER commit secrets to git
# Use .env.example as a template (committed) and .env for actual secrets (ignored)
# ============================================================

# Application URL
BASE_URL=https://demowebshop.tricentis.com

# Test user credentials — stored here, NOT hardcoded in tests
TEST_USER_EMAIL=testuser_pw@example.com
TEST_USER_PASSWORD=Test@12345

# Admin credentials (for admin panel tests)
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=AdminPass123

# API Keys (if applicable)
API_KEY=your-api-key-here

# CI flag — set to 'true' in CI/CD pipelines
# CI=true
